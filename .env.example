# Copilot LLM engine. Set ONE of these to enable a real LLM (priority: Claude > Gemini).
# With neither set, /copilot uses the offline rule-based template engine.

# Anthropic Claude — key starts with sk-ant-api03-...
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — key from https://aistudio.google.com/apikey
GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-flash   # optional override
